# Postgres
DATABASE_URL=postgresql://dcp:dcp@localhost:5433/dcp

# Ollama (only needed when running triage / extraction stages)
# Production triage default is granite4.1:30b — chosen after a five-model
# eval (97% verdict accuracy at ~9s/app). Pull with `ollama pull granite4.1:30b`.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=granite4.1:30b

# Anthropic (only needed for Phase 4 multimodal pass over site plans)
# ANTHROPIC_API_KEY=

# Local storage root for cached raw documents
DATA_DIR=./data
