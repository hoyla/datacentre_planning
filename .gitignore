# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
venv/
.venv/
env/

# Secrets / local config
.env
.env.local
.env.*.local
*.pem
*.key

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# IDE / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Logs
*.log
logs/

# ---------------------------------------------------------------------------
# Editorial / in-flight content
# ---------------------------------------------------------------------------
# Most of data/ is research, labelling, eval outputs, cached source-portal
# responses, and analytical writeups — i.e. pre-publication editorial work.
# Untracked by default; specific operational config is exempted below.
#
# Repo went private 2026-05-14 in case of public exposure; this gitignore
# is belt-and-braces for if the repo ever returns to public.

data/*
data/**/*

# Exempt operational config / methodology that should be versioned:
!data/operators.yaml
!data/triage_labelling/
data/triage_labelling/*
!data/triage_labelling/rubric.md
!data/priors/
data/priors/*
!data/priors/*.yaml
!data/priors/osm/
data/priors/osm/*
!data/priors/osm/*.geojson

# --- Methodology trail (allowed pre-publication while repo is private;
# stays tracked post-publication so a third party can reproduce). The
# `data/raw/`, `data/exports/`, and other point-in-time outputs stay
# blocked — see POST_PUBLICATION_CHECKLIST.md for rationale.
!data/seed_cases/
data/seed_cases/*
!data/seed_cases/walkthrough_findings.md

!data/seed_applications.md

!data/planit_exploration/
data/planit_exploration/*
!data/planit_exploration/findings.md
!data/planit_exploration/sample_data_centre.json

!data/colocated_energy_spike/
data/colocated_energy_spike/*
!data/colocated_energy_spike/findings.md

!data/nsip_research/
data/nsip_research/*
!data/nsip_research/findings.md

!data/prior_art_sources/
data/prior_art_sources/*
!data/prior_art_sources/foxglove_top10.md
!data/prior_art_sources/foxglove_reconciliation.md

# Triage eval reports (markdown only — .jsonl raw outputs stay local,
# regenerate via scripts/eval_triage.py).
!data/triage_labelling/eval_summary.md
!data/triage_labelling/eval_*.md
